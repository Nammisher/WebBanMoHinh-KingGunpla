<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin KingGunpla</title>

    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- CSS (Dùng chung bộ CSS gốc nếu bạn muốn) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* TONE MÀU VS CODE THEME */
        :root {
            --vs-bg-dark: #1e1e1e;
            --vs-sidebar: #252526;
            --vs-border: #3e3e42;
            --vs-blue: #007acc;
            --vs-cyan: #00c6ff;
            --vs-text: #cccccc;
            --vs-text-light: #ffffff;
        }

        body {
            background-color: var(--vs-bg-dark);
            color: var(--vs-text);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
            margin: 0;
        }

        /* KHU VỰC MENU BÊN TRÁI */
        #sidebar {
            width: 260px;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            background-color: var(--vs-sidebar);
            border-right: 1px solid var(--vs-border);
            z-index: 1000;
            padding-top: 20px;
        }

        .sidebar-brand {
            color: var(--vs-cyan);
            font-size: 1.5rem;
            font-weight: bold;
            text-align: center;
            margin-bottom: 30px;
            text-decoration: none;
            display: block;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(0, 198, 255, 0.4);
        }

        .nav-item-admin {
            padding: 12px 20px;
            color: var(--vs-text);
            text-decoration: none;
            display: flex;
            align-items: center;
            transition: all 0.2s;
            border-left: 4px solid transparent;
        }

        /* Hiệu ứng khi Hover hoặc Đang ở trang đó */
        .nav-item-admin:hover, .nav-item-admin.active {
            background-color: #2d2d30;
            color: var(--vs-text-light);
            border-left: 4px solid var(--vs-blue);
        }

        .nav-item-admin i {
            font-size: 1.2rem;
            margin-right: 15px;
            color: var(--vs-cyan);
        }

        /* KHU VỰC NỘI DUNG BÊN PHẢI */
        #main-content {
            margin-left: 260px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* THANH ĐIỀU HƯỚNG TRÊN CÙNG */
        .admin-topbar {
            background-color: var(--vs-sidebar);
            border-bottom: 1px solid var(--vs-border);
            padding: 15px 30px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }

        .admin-content-wrapper {
            padding: 30px;
            flex-grow: 1;
        }

        /* SCROLLBAR ĐẸP NHƯ VS CODE */
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: var(--vs-bg-dark); }
        ::-webkit-scrollbar-thumb { background: #424242; border-radius: 5px; }
        ::-webkit-scrollbar-thumb:hover { background: #4f4f4f; }
    </style>
    @RenderSection("styles", required: false)
</head>
<body>

    <!-- 1. SIDEBAR TRÁI -->
    <div id="sidebar">
        <a href="/Admin/Dashboard" class="sidebar-brand">
            <i class="bi bi-robot"></i> KING<span style="color: white;">GUNPLA</span>
        </a>
        
        <div class="nav flex-column">
            <a href="/Admin/Dashboard" class="nav-item-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Tổng quan
            </a>
            <a href="/Admin/Order" class="nav-item-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Order" ? "active" : "")">
                <i class="bi bi-box-seam"></i> Quản lý Đơn hàng
            </a>
            <a href="/Admin/Product" class="nav-item-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")">
                <i class="bi bi-boxes"></i> Kho Sản phẩm
            </a>
            <a href="/Admin/Category" class="nav-item-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")">
                <i class="bi bi-tags"></i> Danh mục (Loại/Dòng)
            </a>
            <a href="/Admin/User" class="nav-item-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")">
                <i class="bi bi-people"></i> Quản lý Pilot
            </a>
        </div>
    </div>

    <!-- 2. KHU VỰC BÊN PHẢI -->
    <div id="main-content">
        <!-- TOPBAR -->
        <div class="admin-topbar">
            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                    <img src="https://placehold.co/40x40/007acc/ffffff?text=AD" alt="" width="32" height="32" class="rounded-circle me-2">
                    <strong>Commander</strong>
                </a>
                <ul class="dropdown-menu dropdown-menu-dark text-small shadow" aria-labelledby="dropdownUser" style="background-color: var(--vs-sidebar); border-color: var(--vs-border);">
                    <li><a class="dropdown-item" href="/">Trở về Trang Pilot</a></li>
                    <li><hr class="dropdown-divider" style="border-color: var(--vs-border);"></li>
                    <li><a class="dropdown-item text-danger" href="/Account/Logout">Đăng xuất</a></li>
                </ul>
            </div>
        </div>

        <!-- 3. NỘI DUNG ĐỘNG SẼ CHÈN VÀO ĐÂY -->
        <div class="admin-content-wrapper">
            @RenderBody()
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>