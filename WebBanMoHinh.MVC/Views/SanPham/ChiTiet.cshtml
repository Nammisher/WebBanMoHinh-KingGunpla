@model WebBanMoHinh.MVC.Models.SanPhamViewModel

@{
    ViewData["Title"] = Model.TenSp + " - Chi Tiết Mô Hình";
    
    var danhGias = Model.BinhLuanDanhGias?.ToList() ?? new List<WebBanMoHinh.MVC.Models.BinhLuanDanhGiaViewModel>();
    
    double avgStar = danhGias.Any() ? danhGias.Average(x => x.SoSao ?? 0) : 0;
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết mô hình</li>
        </ol>
    </nav>

    <div class="detail-container mb-5">
        <div class="row g-5">
            <div class="col-md-6">
                <div class="product-detail-image-box shadow-sm" style="width: 100%; height: 500px; background-color: rgba(255,255,255,0.02); border: 1px solid var(--border-layout); border-radius: 12px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                    <img src="~/images/ImageProduct/@Model.HinhAnhChinh" 
                         onerror="this.src='https://placehold.co/500x500/1e293b/cbd5e1?text=KingGunpla'" 
                         style="max-width: 100%; max-height: 100%; object-fit: contain;" 
                         alt="@Model.TenSp" />
                </div>
            </div>

            <div class="col-md-6 d-flex flex-column justify-content-between">
                <div>
                    <h1 class="detail-title h2 mb-3 text-uppercase fw-bold">@Model.TenSp</h1>
                    
                    <div class="mb-4 d-flex align-items-center">
                        @if (Model.GiaGiam > 0 && Model.GiaGiam < Model.GiaBan)
                        {
                            <span class="text-danger fw-bold fs-3 me-3">@String.Format("{0:N0}", Model.GiaGiam) đ</span>
                            <span class="text-muted text-decoration-line-through fs-5">@String.Format("{0:N0}", Model.GiaBan) đ</span>
                        }
                        else
                        {
                            <span class="text-danger fw-bold fs-3 me-3">@String.Format("{0:N0}", Model.GiaBan) đ</span>
                        }
                    </div>

                    <div class="spec-table-bay shadow-sm">
                        <table class="table spec-table">
                            <tbody>
                                <tr>
                                    <td class="spec-label"><i class="bi bi-aspect-ratio me-2"></i>Tỷ lệ</td>
                                    <td>@(string.IsNullOrEmpty(Model.TiLe) ? "N/A" : Model.TiLe)</td>
                                </tr>
                                <tr>
                                    <td class="spec-label"><i class="bi bi-arrows-fullscreen me-2"></i>Kích thước</td>
                                    <td>@(string.IsNullOrEmpty(Model.KichThuoc) ? "N/A" : Model.KichThuoc)</td>
                                </tr>
                                <tr>
                                    <td class="spec-label"><i class="bi bi-box-seam me-2"></i>Chất liệu</td>
                                    <td>@(string.IsNullOrEmpty(Model.ChatLieu) ? "Nhựa ABS / PVC cao cấp" : Model.ChatLieu)</td>
                                </tr>
                                <tr>
                                    <td class="spec-label"><i class="bi bi-stack me-2"></i>Tình trạng</td>
                                    <td>
                                        @if (Model.SoLuongTon > 0)
                                        {
                                            <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25 px-2.5 py-1">Còn hàng (@Model.SoLuongTon)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-25 text-danger border border-danger border-opacity-25 px-2.5 py-1">Tạm hết hàng</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mb-4 description-box">
                        <h5 class="text-uppercase fs-6 mb-2 fw-bold">Mô tả sản phẩm</h5>
                        <p class="description-text small text-muted" style="line-height: 1.6;">
                            @(string.IsNullOrEmpty(Model.MoTa) ? "Chưa có mô tả chi tiết cho mô hình này. Sản phẩm fullbox chính hãng nhập khẩu đầy đủ phụ kiện." : Model.MoTa)
                        </p>
                    </div>
                </div>

                <div class="border-top border-secondary border-opacity-10 pt-4">
                    <form action="/Cart/AddToCart" method="post">
                        <input type="hidden" name="maSp" value="@Model.MaSp" />
                        
                        @if (Model.SoLuongTon > 0)
                        {
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <span class="spec-label fw-bold text-uppercase" style="width: auto;">Số lượng mua:</span>
                                <input type="number" name="soLuong" class="form-control text-center" value="1" min="1" max="@Model.SoLuongTon" style="width: 90px; background: var(--bg-card); color: var(--text-main); border: 1px solid var(--border-layout);">
                            </div>

                            <div class="row g-2">
                                <div class="col-6">
                                    <button type="submit" class="btn btn-outline-primary w-100 py-2.5 rounded-pill fw-bold btn-sm text-uppercase">
                                        <i class="bi bi-cart-plus me-2"></i>Thêm Vào Giỏ
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button type="submit" class="btn btn-primary w-100 py-2.5 rounded-pill fw-bold btn-sm text-uppercase" style="background: linear-gradient(135deg, #00c6ff, #0072ff); border:none;">
                                        <i class="bi bi-lightning-fill me-1"></i>Mua Ngay
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-center gap-3 mb-4 opacity-50">
                                <span class="spec-label fw-bold text-uppercase" style="width: auto;">Số lượng mua:</span>
                                <input type="number" class="form-control text-center" value="0" disabled style="width: 90px; background: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border-layout);">
                            </div>

                            <div class="row g-2">
                                <div class="col-12">
                                    <button type="button" class="btn btn-secondary w-100 py-2.5 rounded-pill fw-bold btn-sm text-uppercase opacity-75" disabled>
                                        <i class="bi bi-x-circle me-2"></i>Sản phẩm tạm hết hàng
                                    </button>
                                </div>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="tech-section-bay">
        <div class="tech-section-title-wrapper d-flex justify-content-between align-items-center">
            <h4 class="tech-section-title">ĐÁNH GIÁ TỪ PILOT</h4>
            <div class="text-warning fs-5">
                @for(int i = 1; i <= 5; i++)
                {
                    <i class="bi @(i <= Math.Round(avgStar) ? "bi-star-fill" : "bi-star")"></i>
                }
                <span class="text-muted fs-6 ms-2">(@danhGias.Count đánh giá)</span>
            </div>
        </div>

        @if (danhGias.Any())
        {
            <div class="review-list">
                @foreach (var review in danhGias.OrderByDescending(r => r.NgayBinhLuan))
                {
                    <div class="review-item p-3 mb-3 rounded-3 shadow-sm" style="background: var(--bg-card); border: 1px solid var(--border-layout);">
                        <div class="d-flex justify-content-between mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-secondary bg-opacity-25 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                    <i class="bi bi-person-fill text-muted fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold" style="color: var(--text-main); font-size: 0.9rem;">@review.TenDangNhap</h6>
                                    <small class="text-muted" style="font-size: 0.75rem;">@(review.NgayBinhLuan?.ToString("dd/MM/yyyy HH:mm") ?? "")</small>
                                </div>
                            </div>
                            <div class="text-warning small" style="text-shadow: 0 0 5px rgba(255,193,7,0.4);">
                                @for(int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= (review.SoSao ?? 5) ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>
                        </div>
                        <p class="mb-0 mt-2 text-muted" style="font-size: 0.9rem;">
                            @review.NoiDung
                        </p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-square-text text-muted" style="font-size: 3rem;"></i>
                <p class="mt-3 text-muted">Chưa có hệ thống dữ liệu đánh giá nào cho mô hình này.</p>
                <p class="small" style="color: var(--text-nav-hover);">Hãy hoàn thành đơn hàng để trở thành Pilot đầu tiên đánh giá!</p>
            </div>
        }
    </div>
</div>