@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container my-5 d-flex justify-content-center">
    <div class="card p-5 text-center success-card border-0" style="max-width: 600px; width: 100%;">
        
        <div class="success-icon mb-4">
            <i class="bi bi-check-circle-fill"></i>
        </div>

        <h2 class="fw-bold mb-3 success-title">Đặt hàng thành công!</h2>
        
        <p class="lead success-text mb-4">
            Cảm ơn bạn đã mua sắm tại <strong class="text-brand">KingGunpla</strong>.<br>
            Đơn hàng của bạn đã được ghi nhận và đang chờ xử lý.
        </p>

        <div class="alert success-alert mb-4 text-start d-flex align-items-center" role="alert">
            <i class="bi bi-info-circle fs-5 me-3"></i>
            <small>Bạn có thể theo dõi tiến độ đơn hàng trong mục "Lịch sử đơn hàng"</small>
        </div>

        <div class="d-grid gap-3 d-md-flex justify-content-md-center">
            <a href="/Home/Index" class="btn btn-primary btn-lg px-4 shadow-sm custom-btn-primary">
                <i class="bi bi-cart-plus me-1"></i> Tiếp tục mua sắm
            </a>
            <a href="/Order/History" class="btn btn-lg px-4 custom-btn-outline">
                <i class="bi bi-clock-history me-1"></i> Xem đơn hàng
            </a>
        </div>
    </div>
</div>