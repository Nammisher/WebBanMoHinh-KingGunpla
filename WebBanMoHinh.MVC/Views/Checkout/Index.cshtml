@model WebBanMoHinh.MVC.Models.CheckoutViewModel

@{
    ViewBag.Title = "Thanh toán - KingGunpla";
    var cartItems = ViewBag.Cart as List<WebBanMoHinh.MVC.Models.CartItemViewModel> ?? new List<WebBanMoHinh.MVC.Models.CartItemViewModel>();
    decimal tamTinh = cartItems.Sum(x => x.GiaBan * x.SoLuong);
    int totalItems = cartItems.Sum(x => x.SoLuong);
}

@section styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ================= KINGGUNPLA CYBER STYLE - CHECKOUT ================= */
        .checkout-container { padding: 40px 0; color: var(--text-body); }
        .checkout-wrapper { max-width: 1140px; margin: 0 auto; padding: 0 15px; }
        
        .checkout-header { display: flex; align-items: center; gap: 15px; margin-bottom: 30px; border-bottom: 1px solid var(--border-layout); padding-bottom: 15px; }
        .checkout-header h1 { font-size: 2.2rem; font-weight: 900; margin: 0; text-transform: uppercase; text-shadow: var(--glow-brand); color: var(--text-footer-h5); letter-spacing: 1px;}
        .checkout-header i { font-size: 2.2rem; color: var(--text-nav-hover); filter: drop-shadow(0 0 8px rgba(0, 198, 255, 0.5)); }

        .checkout-content { display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 30px; align-items: start; }
        .customer-section, .shipping-section, .payment-section { background: var(--bg-dropdown); padding: 30px; border-radius: 16px; border: 1px solid var(--border-layout); margin-bottom: 25px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15); }
        
        .section-title { font-size: 1.15rem; font-weight: 800; margin-bottom: 25px; display: flex; align-items: center; gap: 10px; color: var(--text-nav-hover); text-transform: uppercase; letter-spacing: 1px;}
        
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; font-size: 0.85rem; font-weight: 700; margin-bottom: 8px; color: var(--text-nav); text-transform: uppercase; letter-spacing: 0.5px;}
        .checkout-input { width: 100%; padding: 14px 18px; background: var(--bg-search); border: 1px solid var(--border-layout); color: var(--text-search); border-radius: 10px; transition: all 0.3s; font-size: 0.95rem; color-scheme: dark; }
        select.checkout-input option { background-color: var(--bg-dropdown); color: var(--text-dropdown); }
        .checkout-input:focus { border-color: var(--text-nav-hover); outline: none; box-shadow: 0 0 0 4px rgba(0, 198, 255, 0.15); }
        .checkout-input:disabled { opacity: 0.5; cursor: not-allowed; }
        
        .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .three-col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

        .shipping-options, .payment-grid { display: grid; gap: 15px; }
        .payment-grid { grid-template-columns: repeat(3, 1fr); }
        
        .shipping-option, .payment-option { border: 2px solid var(--border-layout); background: rgba(255, 255, 255, 0.02); border-radius: 12px; padding: 18px; cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); position: relative; display: block; }
        .payment-option { text-align: center; }
        .payment-option i { font-size: 2.2rem; color: var(--text-nav); transition: color 0.3s, transform 0.3s; }
        .shipping-option input[type="radio"], .payment-option input[type="radio"] { display: none; }
        
        .shipping-option.selected, .payment-option.selected { border-color: var(--text-nav-hover); background: rgba(0, 198, 255, 0.08); box-shadow: 0 0 20px rgba(0, 198, 255, 0.15); transform: translateY(-2px); }
        .payment-option.selected i { color: var(--text-nav-hover); transform: scale(1.1); filter: drop-shadow(0 0 8px rgba(0,198,255,0.5));}

        .shipping-info { display: block; padding-right: 100px; }
        .shipping-name { font-weight: 800; color: var(--text-footer-h5); letter-spacing: 0.5px;}
        .shipping-desc { font-size: 0.85rem; color: var(--text-nav); margin-top: 6px; line-height: 1.4; }
        .badge-free { background: linear-gradient(135deg, #2ecc71, #27ae60); color: #fff; padding: 5px 12px; border-radius: 30px; font-size: 0.75rem; font-weight: 800; position: absolute; top: 50%; right: 18px; transform: translateY(-50%); box-shadow: 0 4px 10px rgba(46, 204, 113, 0.3); }
        .shipping-price { font-weight: 800; color: var(--text-nav-hover); font-size: 1.1rem; position: absolute; top: 50%; right: 18px; transform: translateY(-50%); }

        .bank-transfer-box { display: flex; gap: 25px; background: rgba(0, 198, 255, 0.05); padding: 25px; border-radius: 12px; margin-top: 20px; border: 1px dashed rgba(0, 198, 255, 0.4); }
        .qr-code img { border-radius: 10px; border: 3px solid var(--border-layout); padding: 5px; background: #fff;}
        .bank-row { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.95rem; border-bottom: 1px solid var(--border-layout); padding-bottom: 8px; align-items: center;}
        .bank-label { color: var(--text-nav); font-weight: 500;}
        .bank-value { font-weight: 800; color: var(--text-footer-h5); }
        .btn-copy { background: rgba(0, 198, 255, 0.1); border: 1px solid var(--text-nav-hover); color: var(--text-nav-hover); border-radius: 6px; font-size: 0.75rem; padding: 4px 10px; cursor: pointer; transition: 0.3s; font-weight: 700;}
        .btn-copy:hover { background: var(--text-nav-hover); color: #fff; box-shadow: 0 0 10px rgba(0, 198, 255, 0.5);}
        .security-notice { background: rgba(46, 204, 113, 0.1); color: #2ecc71; padding: 15px; border-radius: 10px; margin-top: 20px; font-size: 0.9rem; display: flex; align-items: center; gap: 12px; border: 1px solid rgba(46, 204, 113, 0.2);}

        .order-summary { background: var(--bg-dropdown); padding: 30px; border-radius: 16px; border: 1px solid var(--border-layout); position: sticky; top: 100px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); }
        .summary-title { font-size: 1.25rem; font-weight: 900; border-bottom: 1px solid var(--border-layout); padding-bottom: 18px; margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center; color: var(--text-footer-h5); letter-spacing: 0.5px;}
        .summary-title span { font-size: 0.85rem; background: linear-gradient(135deg, #00c6ff, #0072ff); color: #fff; padding: 4px 12px; border-radius: 20px; font-weight: 700; box-shadow: 0 4px 10px rgba(0, 114, 255, 0.3);}
        
        .product-item { display: flex; align-items: center; gap: 18px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px dashed var(--border-layout); }
        .product-image-wrap { position: relative; width: 60px; height: 60px; background: rgba(255,255,255,0.05); border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border-layout);}
        .product-image-wrap img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; }
        .product-qty { position: absolute; top: -8px; right: -8px; background: #ef4444; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: bold; border: 2px solid var(--bg-dropdown); z-index: 5;}
        
        .product-info { flex: 1; }
        .product-name { font-weight: 700; font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: var(--text-footer-h5);}
        .product-price { font-weight: 800; color: var(--text-nav-hover); font-size: 1.05rem;}

        .summary-row { display: flex; justify-content: space-between; margin-bottom: 14px; font-size: 0.95rem; color: var(--text-nav); font-weight: 500;}
        .summary-row-value { font-weight: 700; color: var(--text-body); }
        
        .summary-total { display: flex; justify-content: space-between; margin-top: 25px; padding-top: 25px; border-top: 2px solid var(--border-layout); font-size: 1.2rem; font-weight: 900; color: var(--text-footer-h5); align-items: center;}
        .summary-total-amount { color: #f43f5e; font-size: 1.6rem; text-shadow: 0 0 15px rgba(244, 63, 94, 0.3);}

        .btn-checkout { width: 100%; padding: 18px; margin-top: 30px; background: linear-gradient(135deg, #00c6ff, #0072ff, #7c3aed); background-size: 200% auto; color: white; border: none; border-radius: 12px; font-size: 1.15rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1.5px; cursor: pointer; transition: all 0.4s ease; box-shadow: 0 8px 25px rgba(0, 114, 255, 0.3); display: flex; align-items: center; justify-content: center; gap: 10px;}
        .btn-checkout:hover { background-position: right center; transform: translateY(-3px); box-shadow: 0 12px 30px rgba(0, 198, 255, 0.5); }
        .btn-back { color: var(--text-nav) !important; transition: 0.3s; font-weight: 600;}
        .btn-back:hover { color: var(--text-nav-hover) !important; text-shadow: 0 0 8px rgba(0, 198, 255, 0.4);}

        @@media (max-width: 992px) { .checkout-content { grid-template-columns: 1fr; gap: 20px;} .order-summary { position: static; margin-top: 10px; } .three-col, .two-col, .payment-grid { grid-template-columns: 1fr; } .bank-transfer-box { flex-direction: column; align-items: center; text-align: center;} }
    </style>
}

<div class="checkout-container">
    <div class="checkout-wrapper">
        <div class="checkout-header">
            <i class="fas fa-shopping-cart"></i>
            <h1>Thanh toán</h1>
        </div>

        @if (!ViewData.ModelState.IsValid || TempData["Error"] != null)
        {
            <div class="alert alert-danger fw-bold rounded-4 shadow-sm border-0 mb-4 p-4" style="background-color: #ffe5e5; color: #d63031; border-left: 5px solid #d63031 !important;">
                <h5 class="fw-bold mb-2"><i class="fas fa-exclamation-triangle me-2"></i> Giao dịch bị gián đoạn</h5>
                @if(TempData["Error"] != null) { <p class="mb-1">@TempData["Error"]</p> }
                @Html.ValidationSummary(false, "", new { @class = "mb-0" })
            </div>
        }

        <form method="post" id="checkoutForm" action="@Url.Action("ProcessPayment", "Checkout")">
            <div class="checkout-content">
                
                <div>
                    <div class="customer-section">
                        <div class="section-title"><i class="fas fa-user"></i> Thông tin nhận hàng</div>

                        <div class="form-group two-col">
                            <div>
                                <label>HỌ</label>
                                @Html.TextBoxFor(m => m.CustomerInfo.FirstName, new { @class = "checkout-input", placeholder = "Nguyễn", required = "required" })
                            </div>
                            <div>
                                <label>TÊN</label>
                                @Html.TextBoxFor(m => m.CustomerInfo.LastName, new { @class = "checkout-input", placeholder = "Văn An", required = "required" })
                            </div>
                        </div>

                        <div class="form-group two-col">
                            <div>
                                <label>EMAIL</label>
                                @Html.TextBoxFor(m => m.CustomerInfo.Email, new { @class = "checkout-input", placeholder = "ban@email.com", required = "required", type = "email" })
                            </div>
                            <div>
                                <label>SỐ ĐIỆN THOẠI</label>
                                @Html.TextBoxFor(m => m.CustomerInfo.PhoneNumber, new { @class = "checkout-input", placeholder = "0901 234 567", required = "required", type = "tel", id = "PhoneNumber" })
                            </div>
                        </div>

                        <div class="form-group">
                            <label>ĐỊA CHỈ NHÀ (SỐ NHÀ, TÊN ĐƯỜNG)</label>
                            @Html.TextBoxFor(m => m.CustomerInfo.Address, new { @class = "checkout-input", placeholder = "VD: 123 Lê Lợi...", required = "required", id = "Address" })
                        </div>

                        <div class="form-group mb-3">
                            <label>TỈNH / THÀNH PHỐ</label>
                            <select id="Province" class="checkout-input" required><option value="">Đang tải dữ liệu...</option></select>
                        </div>
                        <div class="form-group two-col mb-3">
                            <div>
                                <label>QUẬN / HUYỆN</label>
                                <select id="District" class="checkout-input" required disabled><option value="">Chọn Quận/Huyện...</option></select>
                            </div>
                            <div>
                                <label>PHƯỜNG / XÃ</label>
                                <select id="Ward" class="checkout-input" required disabled><option value="">Chọn Phường/Xã...</option></select>
                            </div>
                        </div>

                        <input type="hidden" id="FullAddress" name="CustomerInfo.FullAddress" />

                        <div class="form-group">
                            <label>GHI CHÚ ĐƠN HÀNG (TUỲ CHỌN)</label>
                            @Html.TextAreaFor(m => m.CustomerInfo.Note, new { @class = "checkout-input", placeholder = "Yêu cầu đặc biệt, thời gian giao hàng..." })
                        </div>
                    </div>

                    <div class="shipping-section">
                        <div class="section-title"><i class="fas fa-truck"></i> Phương thức vận chuyển</div>
                        <div class="shipping-options">
                            <div class="shipping-option selected" data-value="1">
                                <input type="radio" name="SelectedShippingMethodId" value="1" checked id="shipping_1" />
                                <div class="shipping-info">
                                    <div class="shipping-name">Giao hàng tận nơi</div>
                                    <div class="shipping-desc">Giao hàng tiêu chuẩn 3-5 ngày làm việc</div>
                                </div>
                                <div class="shipping-price">25.000₫</div>
                            </div>

                            <div class="shipping-option" data-value="2">
                                <input type="radio" name="SelectedShippingMethodId" value="2" id="shipping_2" />
                                <div class="shipping-info">
                                    <div class="shipping-name">Nhận tại cửa hàng</div>
                                    <div class="shipping-desc">Đến trực tiếp kho KingGunpla</div>
                                </div>
                                <span class="badge-free">MIỄN PHÍ</span>
                            </div>
                        </div>
                    </div>

                    <div class="payment-section">
                        <div class="section-title"><i class="fas fa-credit-card"></i> Phương thức thanh toán</div>
                        <div class="payment-grid">
                            <div class="payment-option selected" data-value="2">
                                <input type="radio" name="SelectedPaymentMethodId" value="2" checked id="payment_2" />
                                <i class="fas fa-university"></i>
                                <div style="margin-top: 8px; font-weight: 600;">Chuyển khoản</div>
                            </div>
                            
                            <div class="payment-option" data-value="4">
                                <input type="radio" name="SelectedPaymentMethodId" value="4" id="payment_4" />
                                <i class="fas fa-money-bill-wave"></i>
                                <div style="margin-top: 8px; font-weight: 600;">Tiền mặt (COD)</div>
                            </div>
                            
                            <div class="payment-option" data-value="6">
                                <input type="radio" name="SelectedPaymentMethodId" value="6" id="payment_6" />
                                <i class="fas fa-qrcode"></i>
                                <div style="margin-top: 8px; font-weight: 600;">VNPay</div>
                            </div>
                        </div>

                        <div class="payment-details-container mt-3">
                            <div class="payment-details" id="payment-details-2">
                                <div class="bank-transfer-box">
                                    <div class="qr-code" style="width: 150px; height: 150px; overflow: hidden; border-radius: 10px; border: 3px solid var(--border-layout); background: #fff; padding: 0;">
                                        <img src="~/images/qrbank/qr-techcombank.jpg" alt="Mã QR Techcombank" style="width: 100%; height: 100%; object-fit: cover; object-position: center 25%; transform: scale(1.8); border: none; padding: 0;" />
                                    </div>
                                    <div class="bank-info" style="flex: 1;">
                                        <h5>Techcombank</h5>
                                        <p class="text-muted" style="margin-bottom: 15px; font-size: 13px;">Chi nhánh TP.HCM</p>
                                        <div class="bank-row">
                                            <span class="bank-label">Số tài khoản</span>
                                            <span class="bank-value">1907 5257 3370 15</span>
                                            <button type="button" class="btn-copy"><i class="fas fa-copy me-1"></i>Sao chép</button>
                                        </div>
                                        <div class="bank-row">
                                            <span class="bank-label">Chủ tài khoản</span>
                                            <span class="bank-value" style="text-transform: uppercase;">VO HOANG DUY NAM</span>
                                        </div>
                                        <div class="bank-row border-0 mb-0 pb-0">
                                            <span class="bank-label">Nội dung CK</span>
                                            <span class="bank-value">DH#@DateTime.Now.ToString("yyyyMMdd")</span>
                                            <button type="button" class="btn-copy"><i class="fas fa-copy me-1"></i>Sao chép</button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="payment-details" id="payment-details-4" style="display: none;">
                                <div class="security-notice" style="background: rgba(0, 198, 255, 0.1); border-color: rgba(0, 198, 255, 0.2); color: var(--text-nav-hover);">
                                    <i class="fas fa-info-circle"></i> <span>Thanh toán bằng tiền mặt trực tiếp cho nhân viên giao hàng.</span>
                                </div>
                            </div>
                            
                            <div class="payment-details" id="payment-details-6" style="display: none;">
                                <div class="security-notice" style="background: rgba(124, 58, 237, 0.1); border-color: rgba(124, 58, 237, 0.2); color: #a78bfa;">
                                    <i class="fas fa-mobile-alt"></i> Bạn sẽ được chuyển hướng cổng thanh toán VNPay an toàn.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="order-summary">
                    <div class="summary-title">
                        Đơn hàng của bạn <span>@totalItems sản phẩm</span>
                    </div>

                    <div class="summary-items" style="max-height: 350px; overflow-y: auto; padding-right: 10px; padding-top: 15px;">
                        @foreach (var item in cartItems)
                        {
                            <div class="product-item">
                                <div class="position-relative me-3" style="width: 60px; height: 60px; flex-shrink: 0;">
                                    <div style="width: 100%; height: 100%; border-radius: 10px; overflow: hidden; background-color: rgba(255,255,255,0.05); border: 1px solid var(--border-layout); display: flex; align-items: center; justify-content: center;">
                                        <img src="~/images/products/@item.HinhAnhChinh" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://placehold.co/60x60/1e293b/cbd5e1?text=SP'" alt="@item.TenSp" />
                                    </div>
                                    <div class="product-qty">@item.SoLuong</div>
                                </div>

                                <div class="product-info">
                                    <div class="product-name">@item.TenSp</div>
                                </div>
                                <div class="product-price">@item.GiaBan.ToString("N0")₫</div>
                            </div>
                        }
                    </div>

                    <div class="summary-row mt-4">
                        <span class="summary-row-label">Tạm tính</span>
                        <span class="summary-row-value">@tamTinh.ToString("N0")₫</span>
                    </div>
                    
                    <div class="summary-row">
                        <span class="summary-row-label">Phí vận chuyển</span>
                        <span class="summary-row-value" id="displayShippingFee">25.000₫</span>
                    </div>

                    <div class="summary-total">
                        <span class="summary-total-label">Tổng cộng</span>
                        <span class="summary-total-amount" id="displayTotalAmount">@((tamTinh + 25000).ToString("N0"))₫</span>
                    </div>

                    <button type="submit" class="btn-checkout">
                        <i class="fas fa-lock"></i> Đặt hàng ngay
                    </button>

                    <a href="@Url.Action("Index", "Cart")" class="btn-back mt-3" style="display: block; text-align: center; text-decoration: none;">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại giỏ hàng
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            var rawSubTotal = @((long)tamTinh);

            // 1. CHỌN PHƯƠNG THỨC VẬN CHUYỂN
            $('.shipping-option').click(function() {
                $('.shipping-option').removeClass('selected');
                $(this).addClass('selected');
                
                var $radio = $(this).find('input[type="radio"]');
                $radio.prop('checked', true);

                var methodId = $radio.val();
                var shippingFee = 0;

                if (methodId === "1") {
                    shippingFee = 25000;
                    $('#displayShippingFee').text('25.000₫');
                } else {
                    shippingFee = 0;
                    $('#displayShippingFee').text('0₫'); 
                }

                var newTotal = rawSubTotal + shippingFee;
                $('#displayTotalAmount').text(newTotal.toLocaleString('vi-VN') + '₫');
            });

            // 2. CHỌN PHƯƠNG THỨC THANH TOÁN
            $('.payment-option').click(function() {
                $('.payment-option').removeClass('selected');
                $(this).addClass('selected');
                
                var $radio = $(this).find('input[type="radio"]');
                $radio.prop('checked', true);

                var methodId = $radio.val();
                $('.payment-details').hide();
                $('#payment-details-' + methodId).fadeIn(200);
            });

            // 3. COPY NỘI DUNG CHUYỂN KHOẢN
            $('.btn-copy').click(function(e) {
                e.preventDefault();
                var textToCopy = $(this).closest('.bank-row').find('.bank-value').text();
                var $btn = $(this);
                var originalHtml = '<i class="fas fa-copy me-1"></i>Sao chép';
                var successHtml = '<i class="fas fa-check me-1"></i>Đã chép';

                function showSuccess() {
                    $btn.html(successHtml).css({'background-color': '#2ecc71', 'color': '#fff', 'border-color': '#2ecc71'});
                    setTimeout(function() {
                        $btn.html(originalHtml).css({'background-color': '', 'color': '', 'border-color': ''});
                    }, 1500);
                }

                if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(textToCopy).then(showSuccess);
                } else {
                    var textArea = document.createElement("textarea");
                    textArea.value = textToCopy;
                    document.body.appendChild(textArea);
                    textArea.select();
                    document.execCommand("Copy");
                    textArea.remove();
                    showSuccess();
                }
            });

            // 4. LẤY ĐỊA CHỈ TỪ BACKEND
            fetch('/Location/GetProvinces')
                .then(response => {
                    if(!response.ok) throw new Error("HTTP Status " + response.status);
                    return response.json();
                })
                .then(data => {
                    if (data && data.error === 0) {
                        let row = '<option value="">Chọn Tỉnh/Thành...</option>';
                        data.data.forEach(element => {
                            row += `<option data-code="${element.id}" value="${element.full_name}">${element.full_name}</option>`;
                        });
                        $("#Province").html(row);
                    } else {
                        $("#Province").html('<option value="">Lỗi định dạng dữ liệu</option>');
                    }
                })
                .catch(error => {
                    console.error("Fetch lỗi:", error);
                    $("#Province").html('<option value="">Lỗi API. Bấm F12 xem Console!</option>');
                });

            $("#Province").change(function() {
                let code = $(this).find(':selected').data('code');
                $('#Ward').html('<option value="">Chọn Phường/Xã...</option>').prop('disabled', true);
                
                if(code) {
                    $('#District').html('<option value="">Đang tải...</option>').prop('disabled', true);
                    
                    fetch("/Location/GetDistricts/" + code)
                        .then(response => response.json())
                        .then(data => {
                            if (data && data.error === 0) {
                                let row = '<option value="">Chọn Quận/Huyện...</option>';
                                data.data.forEach(element => {
                                    row += `<option data-code="${element.id}" value="${element.full_name}">${element.full_name}</option>`;
                                });
                                $("#District").html(row).prop('disabled', false);
                            }
                        });
                } else {
                    $('#District').html('<option value="">Chọn Quận/Huyện...</option>').prop('disabled', true);
                }
            });

            $("#District").change(function() {
                let code = $(this).find(':selected').data('code');
                
                if(code) {
                    $('#Ward').html('<option value="">Đang tải...</option>').prop('disabled', true);
                    
                    fetch("/Location/GetWards/" + code)
                        .then(response => response.json())
                        .then(data => {
                            if (data && data.error === 0) {
                                let row = '<option value="">Chọn Phường/Xã...</option>';
                                data.data.forEach(element => {
                                    row += `<option data-code="${element.id}" value="${element.full_name}">${element.full_name}</option>`;
                                });
                                $("#Ward").html(row).prop('disabled', false);
                            }
                        });
                } else {
                    $('#Ward').html('<option value="">Chọn Phường/Xã...</option>').prop('disabled', true);
                }
            });

            // 5. BẮT LỖI FORM SUBMIT
            $('#checkoutForm').submit(function (e) {
                var phone = $('#PhoneNumber').val().trim();
                
                if (!/^[0-9]{10,11}$/.test(phone.replace(/\s/g, ''))) {
                    e.preventDefault();
                    alert('Số điện thoại không hợp lệ!');
                    return false;
                }

                var address = $('#Address').val();
                var ward = $('#Ward').val();
                var district = $('#District').val();
                var province = $('#Province').val();

                if(ward && district && province) {
                    var fullAddress = address + ", " + ward + ", " + district + ", " + province;
                    $('#FullAddress').val(fullAddress);
                } else {
                    e.preventDefault();
                    alert('Vui lòng chọn đầy đủ Tỉnh/Thành, Quận/Huyện và Phường/Xã!');
                    return false;
                }
            });
        });
    </script>
}