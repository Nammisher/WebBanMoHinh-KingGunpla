@model WebBanMoHinh.MVC.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng Nhập - KingGunpla";
}
<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #0f172a; color: #f8fafc; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { background: rgba(30, 41, 59, 0.4); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; width: 100%; max-width: 420px; padding: 40px; box-shadow: 0 12px 35px rgba(0, 0, 0, 0.5); }
        .form-control-cyber { background: #111827 !important; border: 1px solid rgba(255, 255, 255, 0.1) !important; color: #ffffff !important; border-radius: 10px; padding: 12px; }
        .form-control-cyber:focus { border-color: #3b82f6 !important; box-shadow: 0 0 12px rgba(59, 130, 246, 0.3); }
        .btn-cyber { background: linear-gradient(135deg, #00c6ff, #0072ff) !important; border: none !important; color: white !important; font-weight: 700; border-radius: 50px; padding: 12px; transition: all 0.3s; }
        .btn-cyber:hover { transform: translateY(-2px); box-shadow: 0 0 15px rgba(0, 198, 255, 0.5); }
    </style>
</head>
<body>
    <div class="login-card text-center">
        <h3 class="fw-bold mb-2 text-uppercase tracking-wider"><i class="bi bi-shield-lock text-info me-2"></i>Pilot Login</h3>
        <p class="text-muted small mb-4">Vui lòng đăng nhập để truy cập tổng kho KingGunpla</p>
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success border-0 small py-2 rounded-3 text-center fw-semibold mb-3">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            </div>
        }
        <div asp-validation-summary="ModelOnly" class="text-danger text-center fw-bold mb-3"></div>
        <form asp-action="Login" asp-controller="Account" method="post">
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="text-start mb-3">
                <label class="form-label small fw-bold">Tài khoản / Email</label>
                <input asp-for="TenDangNhap" class="form-control form-control-cyber" placeholder="Nhập tài khoản..." autocomplete="off" />
                <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
            </div>

            <div class="text-start mb-4">
                <label class="form-label small fw-bold mb-2">Mật khẩu</label>
                <div class="input-group">
                    <input asp-for="MatKhau" id="loginPass" type="password" class="form-control form-control-cyber border-end-0" placeholder="Nhập mật khẩu..." />
                    <span class="input-group-text form-control-cyber border-start-0" style="cursor:pointer;" onclick="togglePassword('loginPass', this)">
                        <i class="bi bi-eye-slash"></i>
                    </span>
                </div>
                <span asp-validation-for="MatKhau" class="text-danger small"></span>
                <div class="text-start mt-2">
                    <a href="/Account/ForgotPassword" class="text-info small text-decoration-none fw-semibold">Quên mật khẩu?</a>
                </div>
            </div>

            <button type="submit" class="btn btn-cyber w-100 text-uppercase mb-3">Đăng Nhập Hệ Thống</button>
            
            <div class="small text-muted">
               Chưa có tài khoản? <a href="/Account/Register" class="text-info text-decoration-none fw-bold">Đăng ký ngay</a>
            </div>

            <div class="mt-4 mb-3">
                <div class="d-flex align-items-center mb-3">
                    <hr class="flex-grow-1 border-secondary m-0" style="opacity: 0.3;">
                    <span class="mx-3 text-uppercase" style="font-size: 12px; color: #8a93a2; font-weight: 500; letter-spacing: 0.5px;">
                        Hoặc đăng nhập bằng
                    </span>
                    <hr class="flex-grow-1 border-secondary m-0" style="opacity: 0.3;">
                </div>
 
                <a href="/Account/GoogleLogin?returnUrl=@Context.Request.Query["returnUrl"]" 
                    class="btn btn-outline-light w-100 mb-3" 
                    style="border-radius: 12px; padding: 10px 0; border: 1px solid #444;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48" class="me-2">
                            <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.354,43.611,20.083z"/>
                            <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
                            <path fill="#4CAF50" d="M24,44c5.166,0,9.898-1.965,13.507-5.185l-6.23-5.275C29.15,35.347,26.732,36,24,36c-5.223,0-9.654-3.343-11.303-8H4v5.303C7.458,40.163,15.116,44,24,44z"/>
                            <path fill="#1976D2" d="M43.611,20.083L43.611,20.083L43.611,20.083z"/>
                            <path fill="#1976D2" d="M43.611,20.083H44v-8.083h-3.389C40.75,15.054,42.062,17.785,43.611,20.083z"/>
                        </svg>
                        Tiếp tục với Google
                </a>
            </div>
        </form>
    </div>
    <script>
        function togglePassword(inputId, toggleElement) {
            const input = document.getElementById(inputId);
            const icon = toggleElement.querySelector('i');
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            }
        }
    </script>
</body>
</html>