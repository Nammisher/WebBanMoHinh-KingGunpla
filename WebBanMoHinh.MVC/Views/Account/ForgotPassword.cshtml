@model WebBanMoHinh.MVC.Models.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Quên Mật Khẩu - KingGunpla";
}
<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #0f172a;
            color: #f8fafc;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 20px;
            width: 100%;
            max-width: 420px;
            padding: 40px;
            box-shadow: 0 12px 35px rgba(0, 0, 0, 0.5);
        }
        .form-control-cyber {
            background: #111827 !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: #ffffff !important;
            border-radius: 10px;
            padding: 12px;
        }
        .form-control-cyber:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 12px rgba(59, 130, 246, 0.3);
        }
        .btn-cyber {
            background: linear-gradient(135deg, #00c6ff, #0072ff) !important;
            border: none !important;
            color: white !important;
            font-weight: 700;
            border-radius: 50px;
            padding: 12px;
            transition: all 0.3s;
        }
        .btn-cyber:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(0, 198, 255, 0.5);
        }
        .icon-circle {
            width: 60px;
            height: 60px;
            background: rgba(0, 198, 255, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px auto;
        }
    </style>
</head>
<body>
    <div class="login-card text-center">
        <div class="icon-circle">
            <i class="bi bi-key-fill text-info fs-3"></i>
        </div>
        <h3 class="fw-bold mb-2 text-uppercase tracking-wider">Quên Mật Khẩu?</h3>
        <p class="text-muted small mb-4">Đừng lo lắng! Hãy nhập địa chỉ Email đăng ký tài khoản, chúng tôi sẽ gửi liên kết để đặt lại mật khẩu cho bạn.</p>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success border-0 small py-2 rounded-3 text-center fw-semibold mb-3">
                <i class="bi bi-envelope-check-fill me-2"></i>@TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger border-0 small py-2 rounded-3 text-center fw-semibold mb-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            </div>
        }

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            <div class="text-start mb-4">
                <label class="form-label small fw-bold">Địa chỉ Email liên kết</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0" style="border-color: rgba(255,255,255,0.1); color: #8a93a2;">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input asp-for="Email" type="email" class="form-control form-control-cyber border-start-0 ps-0" placeholder="pilot@email.com" required autocomplete="off" />
                </div>
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn btn-cyber w-100 text-uppercase mb-4">
                <i class="bi bi-send-fill me-2"></i>Gửi mã khôi phục
            </button>
            
            <div class="small">
                <a href="/Account/Login" class="text-muted text-decoration-none fw-semibold hover-info transition">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại trang Đăng nhập
                </a>
            </div>
        </form>
    </div>
</body>
</html>