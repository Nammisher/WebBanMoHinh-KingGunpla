@model IEnumerable<WebBanMoHinh.MVC.Models.SanPhamViewModel>

@{
    ViewData["Title"] = "Trang Chủ - KingGunpla Model Shop";
    
    // ===================================================================================
    // BỘ LỌC ĐỘNG TỪ DATABASE THEO CỜ ISHOT VÀ MÃ DÒNG SẢN PHẨM (MA DONG)
    // ===================================================================================
    var sanPhamBanChay   = Model?.Where(p => p.IsHot == true).Take(4).ToList() ?? new List<WebBanMoHinh.MVC.Models.SanPhamViewModel>();
    var môHìnhGundamDynamic = Model?.Where(p => p.MaDong == 1).Take(4).ToList() ?? new List<WebBanMoHinh.MVC.Models.SanPhamViewModel>();
    var dsDragonBall      = Model?.Where(p => p.MaDong == 2).Take(4).ToList() ?? new List<WebBanMoHinh.MVC.Models.SanPhamViewModel>();
    var dsOnePiece        = Model?.Where(p => p.MaDong == 3).Take(4).ToList() ?? new List<WebBanMoHinh.MVC.Models.SanPhamViewModel>();
    var dsSuperSentai     = Model?.Where(p => p.MaDong == 4).Take(4).ToList() ?? new List<WebBanMoHinh.MVC.Models.SanPhamViewModel>();
    var dsMotorNuclear    = Model?.Where(p => p.MaNsx == 5).Take(4).ToList() ?? new List<WebBanMoHinh.MVC.Models.SanPhamViewModel>();
}

<div id="kingBanner" class="carousel slide carousel-fade mb-5 shadow" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#kingBanner" data-bs-slide-to="0" class="active" aria-current="true"></button>
        <button type="button" data-bs-target="#kingBanner" data-bs-slide-to="1"></button>
    </div>
    <div class="carousel-inner text-white">
        <div class="carousel-item active">
            <div class="w-100 h-100" style="background: url('https://images.unsplash.com/photo-1607604276583-eef5d076aa5f?q=80&w=1920') center/cover;">
                <div class="container h-100 d-flex align-items-center">
                    <div class="carousel-caption text-start ms-md-5">
                        <span class="badge bg-primary mb-2 text-uppercase px-3 py-2 fw-bold" style="background-color: #3b82f6 !important;">New Era</span>
                        <h1 class="fw-black display-5">KING GUNPLA SHOP</h1>
                        <p class="fs-6 mb-4">Chào mừng Builder đến với tổng kho Robot lắp ráp mô hình tối thượng.<br>Cam kết box sắc nét, full runner nhựa nhập khẩu trực tiếp.</p>
                        <a href="#shop-now" class="btn btn-banner-blue shadow">SĂN KIT NGAY</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="carousel-item">
            <div class="w-100 h-100" style="background: url('https://images.unsplash.com/photo-1563089145-599997674d42?q=80&w=1920') center/cover;">
                <div class="container h-100 d-flex align-items-center justify-content-end">
                    <div class="carousel-caption text-end me-md-5">
                        <span class="badge bg-danger mb-2 text-uppercase px-3 py-2 fw-bold">Live Bidding</span>
                        <h1 class="fw-black display-5">SÀN ĐẤU GIÁ MÔ HÌNH</h1>
                        <p class="fs-6 mb-4">Nơi các tay chơi đích thực săn tìm các phiên bản giới hạn, mạ vàng P-Bandai cực hiếm với mức giá tự quyết định.</p>
                        <a href="/Home/DieuKhoanDauGia" class="btn btn-banner-white shadow">TÌM HIỂU HỆ THỐNG</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#kingBanner" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
    <button class="carousel-control-next" type="button" data-bs-target="#kingBanner" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
</div>

<div class="container mb-5" id="shop-now">
