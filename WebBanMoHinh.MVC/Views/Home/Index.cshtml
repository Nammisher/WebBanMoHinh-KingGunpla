            <h4 class="tech-section-title">KHO MÔ HÌNH SẴN HÀNG</h4>
            <span class="badge px-3 py-2 rounded-pill fw-bold" style="background-color: rgba(59, 130, 246, 0.15); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.3);">Total: @(Model?.Count() ?? 0) Kits</span>
        </div>
        
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 g-md-4">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 product-card">
                            <div class="product-card-img position-relative" style="height: 250px; width: 100%; overflow: hidden; background-color: rgba(255,255,255,0.02); border-radius: 8px 8px 0 0; display: flex; align-items: center; justify-content: center;">
                                <img src="~/images/@item.HinhAnhChinh" onerror="this.src='https://placehold.co/300x250/1e293b/cbd5e1?text=Gunpla'" style="width: 100%; height: 100%; object-fit: cover;" alt="@item.TenSp" />
                            </div>
                            <div class="card-body d-flex flex-column justify-content-between p-3">
                                <div>
                                    <h6 class="card-title fw-bold text-truncate-2lh" title="@item.TenSp">@item.TenSp</h6>
                                    <div class="d-flex gap-2 mb-3" style="font-size: 0.75rem;">
                                        <span>Grade: @(string.IsNullOrEmpty(item.TiLe) ? "N/A" : item.TiLe)</span>
                                        <span>|</span>
                                        <span>@item.ChatLieu</span>
                                    </div>
                                </div>
                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="fw-bold fs-5" style="color: #38bdf8;">@String.Format("{0:N0}", item.GiaBan) đ</span>
