                                    </div>
                                    <a href="/SanPham/ChiTiet/@item.MaSp" class="btn btn-outline-primary btn-custom-action w-100 btn-sm">Xem Chi Tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
