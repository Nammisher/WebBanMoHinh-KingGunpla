@{
    ViewData["Title"] = "Hướng Dẫn Kiểm Tra Runner-Nhựa";
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Hướng dẫn kiểm tra Runner</li>
        </ol>
    </nav>

    <div class="text-center mb-5">
        <h2 class="text-uppercase fw-bold" style="color: var(--text-nav-hover); text-shadow: var(--glow-brand);">
            <i class="bi bi-box-seam me-2"></i> Quy Trình Kiểm Tra Runner Nhựa
        </h2>
        <p style="color: var(--text-muted);">Đảm bảo quyền lợi tối đa cho Pilot khi unbox mô hình tại KingGunpla</p>
    </div>

    <div class="card border-0 shadow-lg rounded-4 p-4 p-md-5 mx-auto" style="max-width: 850px; background-color: var(--bg-card); color: var(--text-main); border: 1px solid var(--border-layout) !important;">
        
        <div class="alert border-0 rounded-3 mb-5 d-flex align-items-center shadow-sm" style="background-color: rgba(0, 198, 255, 0.1); color: var(--text-main); border-left: 4px solid #00c6ff !important;">
            <i class="bi bi-exclamation-triangle-fill fs-3 text-info me-3"></i>
            <div>
                <strong>Lưu ý bắt buộc:</strong> Vui lòng giữ nguyên seal nilon bao bọc runner bên trong hộp cho đến khi bạn hoàn tất việc đối chiếu mã chữ cái với sách hướng dẫn (Manual).
            </div>
        </div>

        <div class="row g-4 position-relative">
            <div class="d-none d-md-block position-absolute" style="left: 24px; top: 20px; bottom: 20px; width: 2px; background-color: var(--border-layout);"></div>

            <div class="col-12 d-flex gap-4">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 50px; height: 50px; z-index: 1;">
                    <i class="bi bi-camera-video-fill fs-5"></i>
                </div>
                <div class="pt-2">
                    <h5 class="fw-bold text-info">Bước 1: Quay video unbox</h5>
                    <p style="color: var(--text-muted);">Đặt điện thoại để quay chi tiết các bước bóc seal kiện hàng vận chuyển (hộp carton bên ngoài).</p>
                </div>
            </div>

            <div class="col-12 d-flex gap-4">
                <div class="rounded-circle bg-info text-dark d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 50px; height: 50px; z-index: 1;">
                    <i class="bi bi-search fs-5"></i>
                </div>
                <div class="pt-2">
                    <h5 class="fw-bold text-info">Bước 2: Quay chi tiết túi Runner</h5>
                    <p style="color: var(--text-muted);">Quay rõ, chậm rãi từng túi runner trong hộp mô hình. <strong class="text-danger">Lưu ý: Không bóc seal nilon của các túi đựng runner.</strong></p>
                </div>
            </div>

            <div class="col-12 d-flex gap-4">
                <div class="rounded-circle bg-warning text-dark d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 50px; height: 50px; z-index: 1;">
                    <i class="bi bi-journal-check fs-5"></i>
                </div>
                <div class="pt-2">
                    <h5 class="fw-bold text-warning">Bước 3: Đối chiếu sách hướng dẫn</h5>
                    <p style="color: var(--text-muted);">Sau khi quay video khui hàng xong thì mở sách hướng dẫn, kiểm tra và đánh dấu từng runner đã bóc túi cho đến khi bóc hết runner ra khỏi túi.</p>
                </div>
            </div>

            <div class="col-12 d-flex gap-4">
                <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 50px; height: 50px; z-index: 1;">
                    <i class="bi bi-chat-dots-fill fs-5"></i>
                </div>
                <div class="pt-2">
                    <h5 class="fw-bold text-success">Bước 4: Liên hệ hỗ trợ</h5>
                    <p style="color: var(--text-muted);">Nếu phát hiện thiếu hoặc lỗi runner nào, Pilot vui lòng Inbox Zalo vào SĐT <strong class="text-dark bg-warning px-2 py-1 rounded fw-bold">0981 260 096</strong> kèm video. Shop chúng mình sẽ liên hệ bên hãng để hãng gửi bù runner cho bạn sớm nhất!</p>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-5">
            <a href="/" class="btn btn-outline-info rounded-pill px-5 fw-bold shadow-sm">Đã hiểu & Trở về Tổng Kho</a>
        </div>
    </div>
</div>